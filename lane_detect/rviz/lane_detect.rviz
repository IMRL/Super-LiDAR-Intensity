Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Current_scan1
        - /STD_descriptor1/Namespaces1
        - /Odometry1/Shape1
      Splitter Ratio: 0.5
    Tree Height: 408
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
      - /FPS1
    Name: Views
    Splitter Ratio: 0.7397769689559937
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: camera _img
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
